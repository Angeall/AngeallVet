# =============================================================================
# AngeallVet - Veterinary Practice Management System
# Configuration File
# Copy this file to .env and adjust values before deployment
# =============================================================================

# --- Application ---
APP_NAME=AngeallVet
# Secure by default. Keep "production" on real deployments (fails closed on the
# default secrets below, enforces the license, hides Swagger). Local dev without
# Docker: set "development". The docker-compose dev stack sets it for you.
APP_ENV=production
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key-in-production
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
DB_ENGINE=postgresql
DB_HOST=db
DB_PORT=5432
DB_NAME=angeallvet
DB_USER=angeallvet
DB_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- Authentication: tenant-local PocketBase ---
# Each tenant runs its OWN PocketBase instance (auth segregation). These values
# configure the DEFAULT tenant; additional tenants store their own URL +
# superuser credentials in the central `tenants` table. The backend reaches
# PocketBase over the internal Docker network (service name), never the
# public sub-domain.
POCKETBASE_URL=http://pocketbase:8090
# PocketBase superuser the backend uses to create/manage application users.
# The docker-compose `pocketbase` service auto-creates this superuser on first
# start (wired to PB_ADMIN_EMAIL/PB_ADMIN_PASSWORD). Min password length: 10.
POCKETBASE_ADMIN_EMAIL=admin@pocketbase.local
POCKETBASE_ADMIN_PASSWORD=change-me-pocketbase-admin

# Per-tenant application JWT signing secret is derived from APP_SECRET_KEY +
# the tenant slug, so a token for one tenant is rejected by another. Set a
# strong APP_SECRET_KEY above in production.

# --- Multi-tenant (sub-domain routing) ---
# Requests are routed to a tenant by the sub-domain of BASE_DOMAIN. No match
# falls back to the DEFAULT tenant (single-clinic deployment / local dev).
BASE_DOMAIN=angeallvet.localhost
DEFAULT_TENANT_SLUG=default
# Central stack serving several tenants: set true so an unknown sub-domain is
# rejected (404) instead of falling back to the central DB. Single-clinic: false.
MULTI_TENANT=false
# Optional Host allow-list (comma list) enforced in production as defense-in-depth
# against Host spoofing. Empty = disabled. e.g. angeallvet.fr,*.angeallvet.fr
TRUSTED_HOSTS=

# Platform super-admin token guarding the cross-tenant registry endpoints
# (/auth/tenants*). Required to use them; a per-tenant ADMIN cannot. Keep empty
# to disable those endpoints entirely.
PLATFORM_ADMIN_TOKEN=

# --- Paid modules (per-tenant license) ---
# Optional modules (sms, invoice_ninja, google_calendar) are unlocked ONLY by a
# cryptographically signed license. The app holds the PUBLIC key, so it verifies
# but never forges: editing this file cannot grant a module without the
# deployer's private key. Generate keys + sign once on the deployer's machine:
#   python -m app.licensing keygen
#   python -m app.licensing sign --key private.pem --tenant <slug> \
#       --modules sms,invoice_ninja --days 365
# LICENSE_PUBLIC_KEY: the verifying key, shipped in every clinic's .env (same
#   key everywhere). Accepts a PEM with escaped \n on one line.
LICENSE_PUBLIC_KEY=
# LICENSE: the signed token issued for THIS clinic. Empty = free tier (simple PDF
#   invoicing + e-mail reminders only).
LICENSE=
# Dev only: with NO public key set in a dev env, all modules are on. Optionally
# restrict to a comma list here. Ignored once LICENSE_PUBLIC_KEY is set, and
# always ignored in production.
DEV_MODULES=
# Seat cap: max active users the admin can create (admin included). 0 = unlimited.
# Plain-.env knob used when no public key is set; once LICENSE_PUBLIC_KEY is set,
# the signed license's `max_users` claim takes over (a clinic can't lift its own
# cap by editing .env). Issue with:  ... sign --max-users 5 ...
MAX_USERS=0

# --- Frontend (set in docker-compose; behind Caddy these stay same-origin) ---
# VITE_API_URL=/api/v1
# VITE_POCKETBASE_URL=        # empty -> derive <origin>/pb

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_NAME=AngeallVet
SMTP_FROM_EMAIL=noreply@example.com
SMTP_TLS=true

# --- SMS (Twilio or OVH) ---
SMS_PROVIDER=twilio
SMS_API_KEY=change-me
SMS_API_SECRET=change-me
SMS_FROM_NUMBER=+33600000000

# --- Google Calendar (google_calendar module — two-way OAuth sync) ---
# Per-vet OAuth: each vet connects their own Google account; refresh tokens are
# stored encrypted (ENCRYPTION_KEY). The REDIRECT_URI must EXACTLY match the
# "Authorized redirect URI" in the Google Cloud OAuth client, and point at the
# public callback below. The free iCal feed needs none of this.
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/agenda/google/callback

# --- Stripe (Payment) ---
STRIPE_SECRET_KEY=sk_test_change-me
STRIPE_WEBHOOK_SECRET=whsec_change-me

# --- File Storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- RGPD / Security ---
# Used by Postgres pgcrypto to encrypt tenant secrets at rest
# (tenants.database_url, tenants.pb_admin_password, per-vet Google refresh tokens).
# REQUIRED in production — the app refuses to start without it (otherwise those
# secrets would be stored in cleartext). Set a strong value and keep it stable
# (rotating it makes existing ciphertext unreadable).
ENCRYPTION_KEY=change-me-to-a-strong-encryption-key
DATA_RETENTION_YEARS=5

# --- Initial Admin (first deployment only) ---
# On first startup, if no users exist in the database, an admin is created
# with these credentials in both Supabase and the local database.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-in-production
INITIAL_ADMIN_FIRST_NAME=Admin
INITIAL_ADMIN_LAST_NAME=AngeallVet

# --- Demo Mode ---
DEMO_MODE=false
SEED_DEMO_DATA=false
