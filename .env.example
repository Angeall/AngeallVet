# =============================================================================
# AngeallVet - Veterinary Practice Management System
# Configuration File
# Copy this file to .env and adjust values before deployment
# =============================================================================

# --- Application ---
APP_NAME=AngeallVet
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key-in-production
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
DB_ENGINE=postgresql
DB_HOST=db
DB_PORT=5432
DB_NAME=angeallvet
DB_USER=angeallvet
DB_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- Supabase Authentication ---
# Create a project at https://supabase.com and fill in these values
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Frontend Supabase (also set in frontend .env or docker-compose)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_NAME=AngeallVet
SMTP_FROM_EMAIL=noreply@example.com
SMTP_TLS=true

# --- SMS (Twilio or OVH) ---
SMS_PROVIDER=twilio
SMS_API_KEY=change-me
SMS_API_SECRET=change-me
SMS_FROM_NUMBER=+33600000000

# --- Google Calendar ---
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/agenda/google/callback

# --- Stripe (Payment) ---
STRIPE_SECRET_KEY=sk_test_change-me
STRIPE_WEBHOOK_SECRET=whsec_change-me

# --- File Storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- RGPD / Security ---
ENCRYPTION_KEY=change-me-32-bytes-key-for-aes256
DATA_RETENTION_YEARS=5

# --- Demo Mode ---
DEMO_MODE=false
SEED_DEMO_DATA=false
