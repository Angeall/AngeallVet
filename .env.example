# =============================================================================
# AngeallVet - Veterinary Practice Management System
# Configuration File
# Copy this file to .env and adjust values before deployment
# =============================================================================

# --- Application ---
APP_NAME=AngeallVet
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key-in-production
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
DB_ENGINE=postgresql
DB_HOST=db
DB_PORT=5432
DB_NAME=angeallvet
DB_USER=angeallvet
DB_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# --- Authentication: tenant-local PocketBase ---
# Each tenant runs its OWN PocketBase instance (auth segregation). These values
# configure the DEFAULT tenant; additional tenants store their own URL +
# superuser credentials in the central `tenants` table. The backend reaches
# PocketBase over the internal Docker network (service name), never the
# public sub-domain.
POCKETBASE_URL=http://pocketbase:8090
# PocketBase superuser the backend uses to create/manage application users.
# The docker-compose `pocketbase` service auto-creates this superuser on first
# start (wired to PB_ADMIN_EMAIL/PB_ADMIN_PASSWORD). Min password length: 10.
POCKETBASE_ADMIN_EMAIL=admin@pocketbase.local
POCKETBASE_ADMIN_PASSWORD=change-me-pocketbase-admin

# Per-tenant application JWT signing secret is derived from APP_SECRET_KEY +
# the tenant slug, so a token for one tenant is rejected by another. Set a
# strong APP_SECRET_KEY above in production.

# --- Multi-tenant (sub-domain routing) ---
# Requests are routed to a tenant by the sub-domain of BASE_DOMAIN. No match
# falls back to the DEFAULT tenant (single-clinic deployment / local dev).
BASE_DOMAIN=angeallvet.localhost
DEFAULT_TENANT_SLUG=default

# Platform super-admin token guarding the cross-tenant registry endpoints
# (/auth/tenants*). Required to use them; a per-tenant ADMIN cannot. Keep empty
# to disable those endpoints entirely.
PLATFORM_ADMIN_TOKEN=

# --- Frontend (set in docker-compose; behind Caddy these stay same-origin) ---
# VITE_API_URL=/api/v1
# VITE_POCKETBASE_URL=        # empty -> derive <origin>/pb

# --- Email (SMTP) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
SMTP_FROM_NAME=AngeallVet
SMTP_FROM_EMAIL=noreply@example.com
SMTP_TLS=true

# --- SMS (Twilio or OVH) ---
SMS_PROVIDER=twilio
SMS_API_KEY=change-me
SMS_API_SECRET=change-me
SMS_FROM_NUMBER=+33600000000

# --- Google Calendar ---
GOOGLE_CLIENT_ID=change-me
GOOGLE_CLIENT_SECRET=change-me
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/agenda/google/callback

# --- Stripe (Payment) ---
STRIPE_SECRET_KEY=sk_test_change-me
STRIPE_WEBHOOK_SECRET=whsec_change-me

# --- File Storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- RGPD / Security ---
# Used by Postgres pgcrypto to encrypt tenant secrets at rest
# (tenants.database_url, tenants.pb_admin_password). Required in production for
# multi-tenant; set a strong value and keep it stable (rotating it makes
# existing ciphertext unreadable).
ENCRYPTION_KEY=change-me-to-a-strong-encryption-key
DATA_RETENTION_YEARS=5

# --- Initial Admin (first deployment only) ---
# On first startup, if no users exist in the database, an admin is created
# with these credentials in both Supabase and the local database.
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-in-production
INITIAL_ADMIN_FIRST_NAME=Admin
INITIAL_ADMIN_LAST_NAME=AngeallVet

# --- Demo Mode ---
DEMO_MODE=false
SEED_DEMO_DATA=false
